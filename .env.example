# Copy to .env and fill in. NEVER commit .env.
# --- Server ---
FRAUDSHIELD_HOST=0.0.0.0
FRAUDSHIELD_PORT=8000
AGGREGATION_STRATEGY=fedprox          # fedavg | fedprox
FEDPROX_MU=0.01
BYZANTINE_DEFENSE=krum                # none | krum | median
NUM_ROUNDS=50
CLIENTS_PER_ROUND=3

# --- Privacy ---
TARGET_EPSILON=5.0
TARGET_DELTA=1e-5                     # ~1/n for smallest partition
MAX_GRAD_NORM=1.0
NOISE_MULTIPLIER=1.1

# --- Tracking ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
